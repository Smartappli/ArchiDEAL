DJANGO_SETTINGS_MODULE=dealhost.settings.dev
DJANGO_SECRET_KEY=<django_secret_key>
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DEALHOST_DB_PATH=/data/db.sqlite3
DEALHOST_API_TOKENS=<service_api_token>
DEALHOST_ADMIN_API_TOKENS=<admin_api_token>
DEALHOST_OIDC_INTROSPECTION_URL=
DEALHOST_OIDC_ISSUER=
DEALHOST_OIDC_AUDIENCE=
DEALHOST_OIDC_CLIENT_ID=
DEALHOST_OIDC_CLIENT_SECRET=
DEALHOST_OIDC_GROUPS_CLAIM=groups
DEALHOST_OIDC_READ_GROUPS=
DEALHOST_OIDC_ADMIN_GROUPS=
DEALHOST_OIDC_TIMEOUT_SECONDS=3
# Optional isolated deployment controller. No runtime operation is simulated
# when this pair is absent. Production requires an HTTPS URL.
DEALHOST_RUNTIME_ENABLED=false
DEALHOST_RUNTIME_CONTROLLER_URL=
DEALHOST_RUNTIME_CONTROLLER_TOKEN=<runtime_controller_token>
DEALHOST_RUNTIME_CONTROLLER_TIMEOUT_SECONDS=15
DEALHOST_RUNTIME_CONTROLLER_CA_FILE=
GITHUB_OWNER=Smartappli
GITHUB_REPOSITORY=ArchiDEAL
GITHUB_ALLOWED_REPOSITORIES=Smartappli/ArchiDEAL
GITHUB_TOKEN=<github_personal_access_token>
GITHUB_WEBHOOK_SECRET=<github_webhook_secret>
APISIX_ADMIN_URL=http://apisix:9180
APISIX_ADMIN_KEY=<apisix_admin_key>
APISIX_UPSTREAM_HOST=django-app
APISIX_UPSTREAM_PORT=8000
# Dynamic routes accept only strict DNS targets on these explicit destinations.
# Development can leave these empty to derive the repository manifest contract.
APISIX_ROUTE_ALLOWED_UPSTREAM_HOSTS=
APISIX_ROUTE_ALLOWED_UPSTREAM_SUFFIXES=
APISIX_ROUTE_ALLOWED_UPSTREAM_PORTS=
# Production also requires canonical exact pairs (host:port) to prevent the
# Cartesian product of the host and port lists from authorizing another target.
APISIX_ROUTE_ALLOWED_UPSTREAMS=
# Additional prefixes are additive; built-ins such as /oauth2, /dealhost,
# /dealiot and /dealdata can never be removed.
APISIX_ROUTE_RESERVED_PATH_PREFIXES=
VALKEY_URL=redis://valkey:6379/1
NATS_URL=nats://nats:4222
NATS_STREAM=dealhost
NATS_SUBJECT_PREFIX=dealhost
NATS_ENABLED=false
