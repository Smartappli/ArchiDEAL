DJANGO_SETTINGS_MODULE=dealhost.settings.dev
DJANGO_SECRET_KEY=<django_secret_key>
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DEALHOST_DB_PATH=/data/db.sqlite3
DEALHOST_API_TOKENS=<service_api_token>
DEALHOST_ADMIN_API_TOKENS=<admin_api_token>
DEALHOST_OIDC_INTROSPECTION_URL=
DEALHOST_OIDC_ISSUER=
DEALHOST_OIDC_AUDIENCE=
DEALHOST_OIDC_CLIENT_ID=
DEALHOST_OIDC_CLIENT_SECRET=
DEALHOST_OIDC_READ_GROUPS=
DEALHOST_OIDC_ADMIN_GROUPS=
DEALHOST_OIDC_TIMEOUT_SECONDS=3
GITHUB_OWNER=Smartappli
GITHUB_REPOSITORY=ArchiDEAL
GITHUB_ALLOWED_REPOSITORIES=Smartappli/ArchiDEAL
GITHUB_TOKEN=<github_personal_access_token>
GITHUB_WEBHOOK_SECRET=<github_webhook_secret>
APISIX_ADMIN_URL=http://apisix:9180
APISIX_ADMIN_KEY=<apisix_admin_key>
APISIX_UPSTREAM_HOST=django-app
APISIX_UPSTREAM_PORT=8000
VALKEY_URL=redis://valkey:6379/1
NATS_URL=nats://nats:4222
NATS_STREAM=dealhost
NATS_SUBJECT_PREFIX=dealhost
NATS_ENABLED=false
