CORE_DJANGO_SECRET_KEY=
GPS_DJANGO_SECRET_KEY=
SENSOR_DJANGO_SECRET_KEY=

CORE_DJANGO_ALLOWED_HOSTS=core.example.org
GPS_DJANGO_ALLOWED_HOSTS=gps.example.org
SENSOR_DJANGO_ALLOWED_HOSTS=sensor.example.org

DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

DEALDATA_INGEST_TOKEN=

CORE_DATABASE_HOST=core-db.example.org
CORE_DATABASE_NAME=dealdata_core
CORE_DATABASE_USER=dealdata
CORE_DATABASE_PASSWORD=
DATABASE_SSLMODE=verify-full
# Source path materialized on the deployment host by the secret manager.
DATABASE_SSLROOTCERT_SOURCE=
# Read-only path created inside each service by docker-compose.prod.yml.
DATABASE_SSLROOTCERT=/run/secrets/dealdata-postgres-ca.crt

GPS_DATABASE_HOST=gps-db.example.org
GPS_DATABASE_NAME=dealdata_gps
GPS_DATABASE_USER=dealdata
GPS_DATABASE_PASSWORD=

SENSOR_DATABASE_HOST=sensor-db.example.org
SENSOR_DATABASE_NAME=dealdata_sensor
SENSOR_DATABASE_USER=dealdata
SENSOR_DATABASE_PASSWORD=

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_SEND_DEFAULT_PII=false

DEALDATA_KAFKA_BOOTSTRAP_SERVERS=kafka1:9092,kafka2:9092,kafka3:9092
DEALDATA_KAFKA_AUTO_OFFSET_RESET=earliest
DEALDATA_KAFKA_MAX_RECORDS=100
DEALDATA_KAFKA_POLL_TIMEOUT_MS=1000
# SASL_SSL is mandatory in the unified production deployment.
DEALDATA_KAFKA_SECURITY_PROTOCOL=SASL_SSL
DEALDATA_KAFKA_SASL_MECHANISM=SCRAM-SHA-512
DEALDATA_KAFKA_SASL_USERNAME=
DEALDATA_KAFKA_SASL_PASSWORD=
# Source path materialized on the deployment host by the secret manager.
DEALDATA_KAFKA_SSL_CAFILE_SOURCE=
# Read-only path created inside each consumer by docker-compose.prod.yml.
DEALDATA_KAFKA_SSL_CAFILE=/run/secrets/dealdata-kafka-ca.crt
DEALDATA_KAFKA_SSL_CERTFILE=
DEALDATA_KAFKA_SSL_KEYFILE=
DEALDATA_KAFKA_SSL_CHECK_HOSTNAME=true
DEALDATA_GPS_KAFKA_TOPIC=raw.gps
DEALDATA_GPS_KAFKA_GROUP_ID=dealdata-gps-ingest
DEALDATA_SENSOR_KAFKA_TOPIC=raw.sensor
DEALDATA_SENSOR_KAFKA_GROUP_ID=dealdata-sensor-ingest
