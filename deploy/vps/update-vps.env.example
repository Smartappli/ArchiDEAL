# Copy to /etc/archideal/update-vps.env, adjust it, then chmod 0600.
# This file contains paths and deployment metadata only. Keep application
# credentials in ARCHIDEAL_ENV_FILE, never in this file or in Git URLs.

ARCHIDEAL_REPO_DIR=/srv/archideal
ARCHIDEAL_REMOTE=origin
ARCHIDEAL_BRANCH=main

# Keep the real Compose secrets outside the checkout when possible. Both this
# file and the Compose environment file must be owned by the cron user and mode
# 0600. A path relative to ARCHIDEAL_REPO_DIR is also accepted.
ARCHIDEAL_ENV_FILE=/etc/archideal/compose.env

ARCHIDEAL_COMPOSE_PROJECT=archideal
ARCHIDEAL_HEALTH_URL=http://127.0.0.1:8080
ARCHIDEAL_HEALTH_TIMEOUT=5m

# 1 asks Docker to refresh base-image layers during a source rebuild. Leaving
# this at 0 makes updates more reproducible and still pulls newly referenced
# images when they are absent locally.
ARCHIDEAL_BUILD_PULL=0

# Normally an unchanged commit is validated and health-checked without a
# rebuild. Set this to 1 only for an explicit repair/redeploy workflow.
ARCHIDEAL_FORCE_REDEPLOY=0

ARCHIDEAL_PYTHON=python3
ARCHIDEAL_LOG_FILE=/var/log/archideal/vps-update.log
ARCHIDEAL_LOCK_FILE=/var/lib/archideal/vps-update.lock
ARCHIDEAL_UPDATE_PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
